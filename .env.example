# Copy to .env.local (or export in your shell) for local dev.
# Neon: Dashboard → Connection details → use "Pooled" for DATABASE_URL and "Direct" for DIRECT_URL.

# App runtime (Neon pooled connection string). Use sslmode=verify-full so the `pg` driver
# does not emit a Node deprecation warning (require/prefer are changing meaning in pg v9).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=verify-full"

# Prisma Migrate / CLI (Neon direct host, no -pooler; avoids pooler + DDL issues)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=verify-full"

# Single URL (e.g. local Postgres): set both to the same connection string, or omit DIRECT_URL.
